__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
runs/
yolo11l.pt
yolo11n.pt
yolo26n.pt
project-1-at-2026-06-30-11-32-249cee2d.zip

# Virtual Environment
.venv/
.venv_win/
env/
venv/
ENV/

# Local caches
.pytest_cache/
.mypy_cache/
.torch/
.ultralytics/
.mplconfig/



# Dataset cache
Objectdetection/dataset/labels/*.cache

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs and databases
*.db
